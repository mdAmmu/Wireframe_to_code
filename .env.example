# Neon Database (PostgreSQL)
NEXT_PUBLIC_NEON_DB_CONNECTION_STRING=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Supabase (Image Storage & Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI (AI Code Generation)
OPENAI_API_KEY=sk-your_openai_api_key

# OpenRouter (Optional - Alternative AI Provider)
# OPENROUTER_AI_API_KEY=your_openrouter_api_key
